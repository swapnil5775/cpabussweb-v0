# Supabase — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — create account at stripe.com → Developers → API Keys
# Also create 4 subscription products (Essentials $149, Growth $249, Enterprise $399)
# and 4 one-time products (LLC Formation $299, Tax Individual $299, Tax Business $499, Payroll Setup $199)
# Then paste the Price IDs below
STRIPE_SECRET_KEY=sk_live_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Subscription plan price IDs
STRIPE_PRICE_ESSENTIALS=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
# One-time service price IDs
STRIPE_PRICE_LLC_FORMATION=price_xxx
STRIPE_PRICE_TAX_INDIVIDUAL=price_xxx
STRIPE_PRICE_TAX_BUSINESS=price_xxx
STRIPE_PRICE_PAYROLL_SETUP=price_xxx
# Site URL (used in Stripe success/cancel redirects)
NEXT_PUBLIC_SITE_URL=https://www.bookkeeping.business

# Resend — dual email notifications for contact form leads
# Sign up free at https://resend.com → API Keys → Create API Key
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_your_api_key_here
# Your verified sending domain in Resend (used as noreply@domain.com)
RESEND_VERIFIED_DOMAIN=webhost4ever.com
# Where YOU receive new lead alerts
NOTIFICATION_EMAIL=you@youremail.com
