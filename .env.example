# Supabase — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — dual email notifications for contact form leads
# Sign up free at https://resend.com → API Keys → Create API Key
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_your_api_key_here
# Your verified sending domain in Resend (used as noreply@domain.com)
RESEND_VERIFIED_DOMAIN=webhost4ever.com
# Where YOU receive new lead alerts
NOTIFICATION_EMAIL=you@youremail.com
